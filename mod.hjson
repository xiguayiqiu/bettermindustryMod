#游戏中显示的模组名称
displayName: "更好的像素工厂"

#模组的内部名称（全小写英文，不要中文、空格）
name: "bettermindustry"

#你的名字
author: "弈秋忘忧白帽"

#模组主类的完全限定名
main: "yiqiu.bettermindustryMod"

#在模组对话框中显示的模组描述（换行使用 \n）
description: "更好的Mindustry游戏体验\n目前功能：\n[字体设置、科技树显示、游戏时间、核心资源显示]"

#模组版本（建议字符串格式）
version: "1.0.0"

repo: "https://github.com/xiguayiqiu/bettermindustryMod"

#运行此模组所需的最低游戏版本
minGameVersion: 158

#这是一个Java模组
java: true